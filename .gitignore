# ==============================================================================
# Financial Analysis Assistant - Master .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Python & Virtual Environments
# ------------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
bin/
include/
lib/
local/
share/

# Python Bytecode & Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Pytest / Coverage / Linting
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
*.pydevdgrid

# ------------------------------------------------------------------------------
# ML Model Checkpoints & Large Artifacts
# ------------------------------------------------------------------------------
model/training/checkpoints/
model/tokenizer/*.model
model/tokenizer/*.vocab
*.pth
*.pt
*.onnx
*.bin
*.safetensors
*.ckpt
*.tflite
*.pb
*.h5

# ------------------------------------------------------------------------------
# Backend & Environment Variables
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.log
*.sqlite
*.sqlite3
*.db
alembic.ini.bak

# ------------------------------------------------------------------------------
# Node.js & Next.js Frontend
# ------------------------------------------------------------------------------
node_modules/
frontend/node_modules/

# Next.js build output
.next/
frontend/.next/
out/
frontend/out/

# Production build artifacts
frontend/build/
frontend/dist/

# Next.js TypeScript declarations & cache
next-env.d.ts
.turbo/
frontend/.turbo/

# Node package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Next.js telemetry / local env files
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ------------------------------------------------------------------------------
# IDEs & System Files
# ------------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (PyCharm / WebStorm / IntelliJ)
.idea/
*.iws
*.iml
*.ipr

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# Scratch Scripts & Temporary Files
# ------------------------------------------------------------------------------
scratch/
tmp/
*.tmp
*.bak
